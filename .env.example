# Publisher — environment configuration
# Copy to .env and fill in. The backend validates these at boot (fail-fast).

# Runtime mode: development | test | production
NODE_ENV=development

# Backend HTTP port
PORT=4000

# SQLite database file path (relative to backend/ cwd)
DATABASE_PATH=./publisher.db

# CORS origin allowed to call the backend (the frontend origin).
# For the deployed demo, set this to your Vercel app origin (D11).
CORS_ORIGIN=http://localhost:3000

# Absolute base URL the backend uses for published-page links (Sink Receipts).
# Local: leave empty (relative URLs). Deployed demo: set to the ngrok https URL
# so the Vercel frontend can iframe published pages through the tunnel (D11).
PUBLIC_BASE_URL=

# --- Agent ---
# The harness defaults to a deterministic, token-free MockAgent.
# Set USE_REAL_AGENT=true to use the real Anthropic-backed agent.
# When true, ANTHROPIC_API_KEY MUST be set (enforced at boot).
USE_REAL_AGENT=false
# ANTHROPIC_API_KEY=sk-ant-...

# --- Frontend (Next.js, NEXT_PUBLIC_* is exposed to the browser) ---
# Local: the backend on :4000. Deployed demo (on Vercel): set to the ngrok
# https URL of your local backend (D11). See DEMO.md for the full deploy flow.
NEXT_PUBLIC_API_BASE=http://localhost:4000
