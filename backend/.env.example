# @publisher/backend — environment configuration
# Copy to .env and fill in values. The backend validates all variables at boot
# and fails fast with a readable error on any misconfiguration.
#
# See HARNESS.md §9 (Running real agents) for the full operator setup guide.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

# Runtime mode: development | test | production
NODE_ENV=development

# HTTP port the backend listens on
PORT=4000

# SQLite database file path (relative to backend/ cwd)
DATABASE_PATH=./publisher.db

# CORS origin allowed to call the backend (the frontend origin).
# Local: http://localhost:3000. Deployed: your Vercel app origin (D11).
CORS_ORIGIN=http://localhost:3000

# Absolute base URL the backend uses for published-page links (Sink receipts).
# Local: leave empty (relative URLs). Deployed: set to the ngrok https URL so
# the Vercel frontend can iframe published pages through the tunnel (D11).
PUBLIC_BASE_URL=

# ---------------------------------------------------------------------------
# Agent (real vs. mock)
# ---------------------------------------------------------------------------

# Master switch. Default: false — the harness uses the deterministic, token-free
# MockAgent (no key needed, no network calls). Set to true to use real Anthropic
# workers. When true, ANTHROPIC_API_KEY MUST also be set (enforced at boot).
USE_REAL_AGENT=false

# Your Anthropic API key. Required when USE_REAL_AGENT=true.
# NEVER commit a real key. Add this file to .gitignore if it contains a real key.
# ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Auth (Epic 85q)
# ---------------------------------------------------------------------------

# HS256 signing secret for bearer-token auth. A dev default is baked in for
# local/test; production MUST override it (the backend fails fast at boot if
# NODE_ENV=production still carries the default).
# AUTH_JWT_SECRET=change-me-to-a-long-random-string

# Admin bootstrap for `npm run seed:admin --workspace backend`. The seeded user
# gets the `admin` role and can see every persona/run. Idempotent: re-running
# with an existing ADMIN_EMAIL leaves that account untouched.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Observability (OpenTelemetry)
# ---------------------------------------------------------------------------

# Master switch for OpenTelemetry. Default: false.
# When true, the run engine emits spans + metrics, and the Prometheus exporter
# serves system metrics on http://localhost:9464/metrics.
# When unset/false, the telemetry API is a no-op (zero behavior change).
OTEL_ENABLED=false

# Optional OTLP/HTTP traces endpoint. When set (and OTEL_ENABLED=true), traces
# are shipped to this collector or Jaeger all-in-one. Leave empty to keep
# traces in-process only.
# Example (local Jaeger): http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_ENDPOINT=
